# backend DB (docker-compose 기본값과 일치)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ingredient_hunter
DB_USER=ingredient
DB_PASSWORD=ingredient

# 비전 LLM 분석 — 우선순위 Gemini > Anthropic > 데모. 실제 키는 .env 에만, 커밋 금지.
# Gemini(연습용 무료): aistudio.google.com 에서 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
ANTHROPIC_API_KEY=

# 식약처 식품안전나라 OpenAPI (품목제조보고 원재료, POC enrich) — foodsafetykorea 인증키
MFDS_KEY=

# 네이버 검색 오픈API (쇼핑 제품 리스트 수집, POC naver_list) — developers.naver.com
NAVER_ID=
NAVER_SECRET=
